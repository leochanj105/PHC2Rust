 and an offset and return a bool / u8.                                 */\n97\t/* --------------------------------------------------------------------- */\n98\t\n99\t#[inline]\n100\tpub unsafe fn CHECK_AT(string: yaml_string_t, octet: u8, offset: isize) -> bool {\n101\t    *string.pointer.offset(offset) == octet\n102\t}\n103\t\n104\t#[inline]\n105\tpub unsafe fn CHECK(string: yaml_string_t, octet: u8) -> bool {\n106\t    CHECK_AT(string, octet, 0)\n107\t}\n108\t\n109\t#[inline]\n110\tpub unsafe fn IS_ALPHA_AT(string: yaml_string_t, offset: isize) -> bool {\n111\t    let c = *string.pointer.offset(offset);\n112\t    (c >= b'0' && c <= b'9')\n113\t        || (c >= b'A' && c <= b'Z')\n114\t        || (c >= b'a' && c <= b'z')\n115\t        || c == b'_'\n116\t        || c == b'-'\n117\t}\n118\t#[inline]\n119\tpub unsafe fn IS_ALPHA(string: yaml_string_t) -> bool {\n120\t    IS_ALPHA_AT(string, 0)\n121\t}\n122\t\n123\t#[inline]\n124\tpub unsafe fn IS_DIGIT_AT(string: yaml_string_t, offset: isize) -> bool {\n125\t    let c = *string.pointer.offset(offset);\n126\t    c >= b'0' && c <= b'9'\n127\t}\n128\t#[inline]\n129\tpub unsafe fn IS_DIGIT(string: yaml_string_t) -> bool {\n130\t    IS_DIGIT_AT(string, 0)\n131\t}\n132\t\n133\t#[inline]\n134\tpub unsafe fn AS_DIGIT_AT(string: yaml_string_t, offset: isize) -> c_int {\n135\t    (*string.pointer.offset(offset) as c_int) - (b'0' as c_int)\n136\t}\n137\t#[inline]\n138\tpub unsafe fn AS_DIGIT(string: yaml_string_t) -> c_int {\n139\t    AS_DIGIT_AT(string, 0)\n140\t}\n141\t\n142\t#[inline]\n143\tpub unsafe fn IS_HEX_AT(string: yaml_string_t, offset: isize) -> bool {\n144\t    let c = *string.pointer.offset(offset);\n145\t    (c >= b'0' && c <= b'9') || (c >= b'A' && c <= b'F') || (c >= b'a' && c <= b'f')\n146\t}\n147\t#[inline]\n148\tpub unsafe fn IS_HEX(string: yaml_string_t) -> bool {\n149\t    IS_HEX_AT(string, 0)\n150\t}\n151\t\n152\t#[inline]\n153\tpub unsafe fn AS_HEX_AT(string: yaml_string_t, offset: isize) -> c_int {\n154\t    let c = *string.pointer.offset(offset);\n155\t    if c >= b'A' && c <= b'F' {\n156\t        (c as c_int) - (b'A' as c_int) + 10\n157\t    } else if c >= b'a' && c <= b'f' {\n158\t        (c as c_int) - (b'a' as c_int) + 10\n159\t    } else {\n160\t        (c as c_int) - (b'0' as c_int)\n161\t    }\n162\t}\n163\t#[inline]\n164\tpub unsafe fn AS_HEX(string: yaml_string_t) -> c_int {\n165\t    AS_HEX_AT(string, 0)\n166\t}\n167\t\n168\t#[inline]\n169\tpub unsafe fn IS_ASCII_AT(string: yaml_string_t, offset: isize) -> bool {\n170\t    *string.pointer.offset(offset) <= 0x7F\n171\t}\n172\t#[inline]\n173\tpub unsafe fn IS_ASCII(string: yaml_string_t) -> bool {\n174\t    IS_ASCII_AT(string, 0)\n175\t}\n176\t\n177\t#[inline]\n178\tpub unsafe fn IS_PRINTABLE_AT(string: yaml_string_t, offset: isize) -> bool {\n179\t    let p = string.pointer.offset(offset);\n180\t    let c0 = *p;\n181\t    (c0 == 0x0A)\n182\t        || (c0 >= 0x20 && c0 <= 0x7E)\n183\t        || (c0 == 0xC2 && *p.add(1) >= 0xA0)\n184\t        || (c0 > 0xC2 && c0 < 0xED)\n185\t        || (c0 == 0xED && *p.add(1) < 0xA0)\n186\t        || (c0 == 0xEE)\n187\t        || (c0 == 0xEF\n188\t            && !(*p.add(1) == 0xBB && *p.add(2) == 0xBF)\n189\t            && !(*p.add(1) == 0xBF && (*p.add(2) == 0xBE || *p.add(2) == 0xBF)))\n190\t}\n191\t#[inline]\n192\tpub unsafe fn IS_PRINTABLE(string: yaml_string_t) -> bool {\n193\t    IS_PRINTABLE_AT(string, 0)\n194\t}\n195\t\n196\t#[inline]\n197\tpub unsafe fn IS_Z_AT(string: yaml_string_t, offset: isize) -> bool {\n198\t    CHECK_AT(string, b'\\0', offset)\n199\t}\n200\t#[inline]\n201\tpub unsafe fn IS_Z(string: yaml_string_t) -> bool {\n202\t    IS_Z_AT(string, 0)\n203\t}\n204\t\n205\t#[inline]\n206\tpub unsafe fn IS_BOM_AT(string: yaml_string_t, offset: isize) -> bool {\n207\t    CHECK_AT(string, 0xEF, offset)\n208\t        && CHECK_AT(string, 0xBB, offset + 1)\n209\t        && CHECK_AT(string, 0xBF, offset + 2)\n210\t}\n211\t#[inline]\n212\tpub unsafe fn IS_BOM(string: yaml_string_t) -> bool {\n213\t    IS_BOM_AT(string, 0)\n214\t}\n215\t\n216\t#[inline]\n217\tpub unsafe fn IS_SPACE_AT(string: yaml_string_t, offset: isize) -> bool {\n218\t    CHECK_AT(string, b' ', offset)\n219\t}\n220\t#[inline]\n221\tpub unsafe fn IS_SPACE(string: yaml_string_t) -> bool {\n222\t    IS_SPACE_AT(string, 0)\n223\t}\n224\t\n225\t#[inline]\n226\tpub unsafe fn IS_TAB_AT(string: yaml_string_t, offset: isize) -> bool {\n227\t    CHECK_AT(string, b'\\t', offset)\n228\t}\n229\t#[inline]\n230\tpub unsafe fn IS_TAB(string: yaml_string_t) -> bool {\n231\t    IS_TAB_AT(string, 0)\n232\t}\n233\t\n234\t#[inline]\n235\tpub unsafe fn IS_BLANK_AT(string: yaml_string_t, offset: isize) -> bool {\n236\t    IS_SPACE_AT(string, offset) || IS_TAB_AT(string, offset)\n237\t}\n238\t#[inline]\n239\tpub unsafe fn IS_BLANK(string: yaml_string_t) -> bool {\n240\t    IS_BLANK_AT(string, 0)\n241\t}\n242\t\n243\t#[inline]\n244\tpub unsafe fn IS_BREAK_AT(string: yaml_string_t, offset: isize) -> bool {\n245\t    CHECK_AT(string, b'\\r', offset)\n246\t        || CHECK_AT(string, b'\\n', offset)\n247\t        || (CHECK_AT(string, 0xC2, offset) && CHECK_AT(string, 0x85, offset + 1))\n248\t        || (CHECK_AT(string, 0xE2, offset)\n249\t            && CHECK_AT(string, 0x80, offset + 1)\n250\t            && CHECK_AT(string, 0xA8, offset + 2))\n251\t        || (CHECK_AT(string, 0xE2, offset)\n252\t            && CHECK_AT(string, 0x80, offset + 1)\n253\t            && CHECK_AT(string, 0xA9, offset + 2))\n254\t}\n255\t#[inline]\n256\tpub unsafe fn IS_BREAK(string: yaml_string_t) -> bool {\n257\t    IS_BREAK_AT(string, 0)\n258\t}\n259\t\n260\t#[inline]\n261\tpub unsafe fn IS_CRLF_AT(string: yaml_string_t, offset: isize) -> bool {\n262\t    CHECK_AT(string, b'\\r', offset) && CHECK_AT(string, b'\\n', offset + 1)\n263\t}\n264\t#[inline]\n265\tpub unsafe fn IS_CRLF(string: yaml_string_t) -> bool {\n266\t    IS_CRLF_AT(string, 0)\n267\t}\n268\t\n269\t#[inline]\n270\tpub unsafe fn IS_BREAKZ_AT(string: yaml_string_t, offset: isize) -> bool {\n271\t    IS_BREAK_AT(string, offset) || IS_Z_AT(string, offset)\n272\t}\n273\t#[inline]\n274\tpub unsafe fn IS_BREAKZ(string: yaml_string_t) -> bool {\n275\t    IS_BREAKZ_AT(string, 0)\n276\t}\n277\t\n278\t#[inline]\n279\tpub unsafe fn IS_SPACEZ_AT(string: yaml_string_t, offset: isize) -> bool {\n280\t    IS_SPACE_AT(string, offset) || IS_BREAKZ_AT(string, offset)\n281\t}\n282\t#[inline]\n283\tpub unsafe fn IS_SPACEZ(string: yaml_string_t) -> bool {\n284\t    IS_SPACEZ_AT(string, 0)\n285\t}\n286\t\n287\t#[inline]\n288\tpub unsafe fn IS_BLANKZ_AT(string: yaml_string_t, offset: isize) -> bool {\n289\t    IS_BLANK_AT(string, offset) || IS_BREAKZ_AT(string, offset)\n290\t}\n291\t#[inline]\n292\tpub unsafe fn IS_BLANKZ(string: yaml_string_t) -> bool {\n293\t    IS_BLANKZ_AT(string, 0)\n294\t}\n295\t\n296\t#[inline]\n297\tpub unsafe fn WIDTH_AT(string: yaml_string_t, offset: isize) -> c_int {\n298\t    let c = *string.pointer.offset(offset);\n299\t    if (c & 0x80) == 0x00 {\n300\t        1\n301\t    } else if (c & 0xE0) == 0xC0 {\n302\t        2\n303\t    } else if (c & 0xF0) == 0xE0 {\n304\t        3\n305\t    } else if (c & 0xF8) == 0xF0 {\n306\t        4\n307\t    } else {\n308\t        0\n309\t    }\n310\t}\n311\t#[inline]\n312\tpub unsafe fn WIDTH(string: yaml_string_t) -> c_int {\n313\t    WIDTH_AT(string, 0)\n314\t}\n315\t\n316\t/* --------------------------------------------------------------------- */\n317\t/*  Buffer/stack/queue macros.\n318\t *\n319\t *  Each of these mirrors a `#define FOO(context,...)` macro in\n320\t *  yaml_private.h.  We expose them as `macro_rules!` so translated source\n321\t *  can keep the same call style, and so the implicit `context->error`\n322\t *  assignment is preserved.                                              */\n323\t/* --------------------------------------------------------------------- */\n324\t\n325\t#[macro_export]\n326\tmacro_rules! BUFFER_INIT {\n327\t    ($context:expr, $buffer:expr, $size:expr) => {{\n328\t        let __sz: libc::size_t = $size;\n329\t        let __p = $crate::yaml_private::yaml_malloc(__sz) as *mut $crate::yaml::yaml_char_t;\n330\t        if !__p.is_null() {\n331\t            $buffer.start = __p;\n332\t            $buffer.pointer = __p;\n333\t            $buffer.last = __p;\n334\t            $buffer.end = __p.add(__sz);\n335\t            1\n336\t        } else {\n337\t            (*$context).error = $crate::yaml::YAML_MEMORY_ERROR;\n338\t            0\n339\t        }\n340\t    }};\n341\t}\n342\t\n343\t#[macro_export]\n344\tmacro_rules! BUFFER_DEL {\n345\t    ($context:expr, $buffer:expr) => {{\n346\t        $crate::yaml_private::yaml_free($buffer.start as *mut libc::c_void);\n347\t        $buffer.start = core::ptr::null_mut();\n348\t        $buffer.pointer = core::ptr::null_mut();\n349\t        $buffer.end = core::ptr::null_mut();\n350\t    }};\n351\t}\n352\t\n353\t#[macro_export]\n354\tmacro_rules! STRING_INIT {\n355\t    ($context:expr, $string:expr, $size:expr) => {{\n356\t        let __sz: libc::size_t = $size;\n357\t        let __p = $crate::yaml_private::yaml_malloc(__sz) as *mut $crate::yaml::yaml_char_t;\n358\t        if !__p.is_null() {\n359\t            $string.start = __p;\n360\t            $string.pointer = __p;\n361\t            $string.end = __p.add(__sz);\n362\t            libc::memset(__p as *mut libc::c_void, 0, __sz);\n363\t            1\n364\t        } else {\n365\t            (*$context).error = $crate::yaml::YAML_MEMORY_ERROR;\n366\t            0\n367\t        }\n368\t    }};\n369\t}\n370\t\n371\t#[macro_export]\n372\tmacro_rules! STRING_DEL {\n373\t    ($context:expr, $string:expr) => {{\n374\t        $crate::yaml_private::yaml_free($string.start as *mut libc::c_void);\n375\t        $string.start = core::ptr::null_mut();\n376\t        $string.pointer = core::ptr::null_mut();\n377\t        $string.end = core::ptr::null_mut();\n378\t    }};\n379\t}\n380\t\n381\t#[macro_export]\n382\tmacro_rules! STRING_EXTEND {\n383\t    ($context:expr, $string:expr) => {{\n384\t        if $string.pointer.add(5) < $string.end\n385\t            || $crate::yaml_private::yaml_string_extend(\n386\t                &mut $string.start,\n387\t                &mut $string.pointer,\n388\t                &mut $string.end,\n389\t            ) != 0\n390\t        {\n391\t            1\n392\t        } else {\n393\t            (*$context).error = $crate::yaml::YAML_MEMORY_ERROR;\n394\t            0\n395\t        }\n396\t    }};\n397\t}\n398\t\n399\t#[macro_export]\n400\tmacro_rules! CLEAR {\n401\t    ($context:expr, $string:expr) => {{\n402\t        $string.pointer = $string.start;\n403\t        libc::memset(\n404\t            $string.start as *mut libc::c_void,\n405\t            0,\n406\t            ($string.end as usize - $string.start as usize),\n407\t        );\n408\t    }};\n409\t}\n410\t\n411\t#[macro_export]\n412\tmacro_rules! JOIN {\n413\t    ($context:expr, $string_a:expr, $string_b:expr) => {{\n414\t        if $crate::yaml_private::yaml_string_join(\n415\t            &mut $string_a.start,\n416\t            &mut $string_a.pointer,\n417\t            &mut $string_a.end,\n418\t            &mut $string_b.start,\n419\t            &mut $string_b.pointer,\n420\t            &mut $string_b.end,\n421\t        ) != 0\n422\t        {\n423\t            $string_b.pointer = $string_b.start;\n424\t            1\n425\t        } else {\n426\t            (*$context).error = $crate::yaml::YAML_MEMORY_ERROR;\n427\t            0\n428\t        }\n429\t    }};\n430\t}\n431\t\n432\t#[macro_export]\n433\tmacro_rules! STACK_INIT {\n434\t    ($context:expr, $stack:expr, $type:ty) => {{\n435\t        let __elem_size = core::mem::size_of::<$type>() as libc::size_t;\n436\t        let __p = $crate::yaml_private::yaml_malloc(\n437\t            ($crate::yaml_private::INITIAL_STACK_SIZE * __elem_size),\n438\t        ) as *mut $type;\n439\t        if !__p.is_null() {\n440\t            $stack.start = __p;\n441\t            $stack.top = __p;\n442\t            $stack.end = __p.add($crate::yaml_private::INITIAL_STACK_SIZE);\n443\t            1\n444\t        } else {\n445\t            (*$context).error = $crate::yaml::YAML_MEMORY_ERROR;\n446\t            0\n447\t        }\n448\t    }};\n449\t}\n450\t\n451\t#[macro_export]\n452\tmacro_rules! STACK_DEL {\n453\t    ($context:expr, $stack:expr) => {{\n454\t        $crate::yaml_private::yaml_free($stack.start as *mut libc::c_void);\n455\t        $stack.start = core::ptr::null_mut();\n456\t        $stack.top = core::ptr::null_mut();\n457\t        $stack.end = core::ptr::null_mut();\n458\t    }};\n459\t}\n460\t\n461\t#[macro_export]\n462\tmacro_rules! STACK_EMPTY {\n463\t    ($context:expr, $stack:expr) => {\n464\t        $stack.start == $stack.top\n465\t    };\n466\t}\n467\t\n468\t#[macro_export]\n469\tmacro_rules! STACK_LIMIT {\n470\t    ($context:expr, $stack:expr, $size:expr) => {{\n471\t        if ($stack.top.offset_from($stack.start) as libc::c_int) < $size {\n472\t            1\n473\t        } else {\n474\t            (*$context).error = $crate::yaml::YAML_MEMORY_ERROR;\n475\t            0\n476\t        }\n477\t    }};\n478\t}\n479\t\n480\t#[macro_export]\n481\tmacro_rules! PUSH {\n482\t    ($context:expr, $stack:expr, $value:expr) => {{\n483\t        let __ok = if $stack.top != $stack.end {\n484\t            true\n485\t        } else {\n486\t            $crate::yaml_private::yaml_stack_extend(\n487\t                &mut $stack.start as *mut _ as *mut *mut libc::c_void,\n488\t                &mut $stack.top as *mut _ as *mut *mut libc::c_void,\n489\t                &mut $stack.end as *mut _ as *mut *mut libc::c_void,\n490\t            ) != 0\n491\t        };\n492\t        if __ok {\n493\t            *$stack.top = $value;\n494\t            $stack.top = $stack.top.add(1);\n495\t            1\n496\t        } else {\n497\t            (*$context).error = $crate::yaml::YAML_MEMORY_ERROR;\n498\t            0\n499\t        }\